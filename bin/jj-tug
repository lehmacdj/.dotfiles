#!/usr/bin/env bash
set -euo pipefail

from="heads(::push_point() & bookmarks())"
to="coalesce(push_point() ~ unpushable(), push_point()- ~ unpushable() & bookmarks()::)"

# allow restricting to a particular bookmark name/revision by supplying an
# argument
if [ "$#" -eq 1 ]; then
  # Limit to descendants of $1, or mutable ancestors of $1.
  # Using ($1:: | ::$1 & mutable()) would be expensive because ::$1 traverses
  # full history. Instead, use trunk().. to bound the ancestor search.
  relevant="($1:: | trunk()..$1)"
  from="$from & $relevant"
  to="$to & $relevant"
fi

# Extract unpushable commits that block pushable commits from being
# tugged forward. A "blocker" is an unpushable commit between the
# bookmark and @ that is an ancestor of a pushable commit in that
# range. Commits already above all pushable commits aren't blockers.
# Rebase the blocker revset as a single unit so jj preserves graph edges
# within the set and does not expose transient conflicted states.
range="($from..@-)"
pushable="$range ~ unpushable()"
blockers="$range & unpushable() & ancestors($pushable)"

if jj log --no-graph -r "$blockers" -T 'change_id' 2>/dev/null | grep -q .; then
  jj rebase -r "$blockers" -B @
fi

jj bookmark move --from "$from" --to "$to"
